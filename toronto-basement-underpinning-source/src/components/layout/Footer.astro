---
import navigation from '../../config/navigation.json';
import site from '../../config/site.json';

const columns = navigation.footer.columns;
const year = new Date().getFullYear();
---

<footer class="bg-primary-800 text-white pt-16 pb-8 mt-0">
  <div class="max-w-container mx-auto px-4">
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-5 gap-8 mb-12">
      <div class="lg:col-span-1">
        <a href="/" class="flex items-center gap-2 mb-4 focus-ring">
          <img src="/favicon.svg" alt={site.name} class="h-10 w-10" />
          <span class="font-heading font-bold uppercase tracking-tight text-sm leading-tight">
            Toronto Basement<br />Underpinning
          </span>
        </a>
        <p class="text-sm text-primary-200 leading-relaxed mb-4">
          {site.shortTagline} 20 dedicated crews. Hundreds of completed projects.
        </p>
        <div class="space-y-3 text-sm">
          <!-- Row 1: Phone -->
          <div class="flex items-center gap-3">
            <div class="flex-shrink-0 w-9 h-9 flex items-center justify-center" style="background-color: #FF7E21;">
              <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
            </div>
            <div>
              <span class="block text-[10px] uppercase tracking-widest text-primary-200 leading-none">Call Now</span>
              <a href="tel:+14169004982" class="block font-bold text-white hover:text-accent-300">(416) 900-4982</a>
            </div>
          </div>
          <!-- Row 2: Message -->
          <div class="flex items-center gap-3">
            <div class="flex-shrink-0 w-9 h-9 flex items-center justify-center" style="background-color: #FF7E21;">
              <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="20" height="16" x="2" y="4" rx="2"/><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/></svg>
            </div>
            <div>
              <span class="block text-[10px] uppercase tracking-widest text-primary-200 leading-none">Send a Message</span>
              <a href="/contact/" class="block font-bold text-white hover:text-accent-300">Use Our Contact Form</a>
            </div>
          </div>
          <!-- Row 3: Map Pin -->
          <div class="flex items-center gap-3">
            <div class="flex-shrink-0 w-9 h-9 flex items-center justify-center" style="background-color: #FF7E21;">
              <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 10c0 6-8 12-8 12s-8-6-8-12a8 8 0 0 1 16 0Z"/><circle cx="12" cy="10" r="3"/></svg>
            </div>
            <div>
              <span class="block text-[10px] uppercase tracking-widest text-primary-200 leading-none">Service Area</span>
              <span class="block font-bold text-white">Toronto, Ontario, Canada</span>
            </div>
          </div>
        </div>
      </div>

      {columns.map((col) => (
        <div>
          <h3 class="font-heading text-xs font-bold uppercase tracking-widest text-accent-400 mb-4">
            {col.title}
          </h3>
          <ul class="space-y-2">
            {col.links.map((link) => (
              <li>
                <a
                  href={link.href}
                  class="text-sm text-primary-100 hover:text-white transition-colors focus-ring"
                >
                  {link.label}
                </a>
              </li>
            ))}
          </ul>
        </div>
      ))}
    </div>

    <div class="border-t border-primary-700 pt-6 text-sm text-primary-300">
      <div class="flex flex-col md:flex-row md:items-center md:justify-between gap-4">
        <p>
          &copy; {year} {site.name}. Fully licensed and insured general contractors.
        </p>
        <div class="flex gap-6">
          <a href="/privacy-policy/" class="hover:text-white">Privacy Policy</a>
          <a href="/terms-of-service/" class="hover:text-white">Terms of Service</a>
        </div>
      </div>
      <p class="mt-3 text-xs text-primary-400 max-w-3xl leading-relaxed">
        Hours: Mon-Fri 8:00 AM &ndash; 6:00 PM &middot; Saturday 9:00 AM &ndash; 3:00 PM &middot; Sunday Closed.
        Service area: Greater Toronto Area, including Toronto, North York, Etobicoke, Scarborough, York, East York, Mississauga, Brampton, Markham, Vaughan, Richmond Hill, Oakville, Burlington, Pickering and surrounding regions.
      </p>
    </div>
  </div>
</footer>
