---
import navigation from '../../config/navigation.json';
import site from '../../config/site.json';

const logoConfig = navigation.header.logo;
const sizeClasses: Record<string, string> = {
  small: 'h-6 w-6',
  medium: 'h-8 w-8',
  large: 'h-10 w-10',
};
const logoSizeClass = sizeClasses[logoConfig.size] || sizeClasses.medium;
const menu = navigation.header.menu;
const cta = navigation.header.cta;
---

<header
  id="site-header"
  class="sticky top-0 left-0 right-0 z-50 bg-white border-b border-brand-border shadow-sm"
>
  <div class="bg-primary-800 text-white text-xs">
    <div class="max-w-container mx-auto px-4 py-2 flex flex-col sm:flex-row items-center justify-between gap-2">
      <div class="flex items-center gap-4 flex-wrap justify-center">
        <span class="flex items-center gap-1.5">
          <span class="material-symbols-outlined-fallback inline-block w-4 h-4">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="w-4 h-4 text-accent-500">
              <path d="M12 .587l3.668 7.568L24 9.75l-6 5.852L19.336 24 12 19.897 4.664 24 6 15.602 0 9.75l8.332-1.595z"/>
            </svg>
          </span>
          <span>{site.trustIndicators.rating} Stars on {site.trustIndicators.ratingSource} ({site.trustIndicators.ratingCount})</span>
        </span>
        <span class="hidden sm:inline-block">|</span>
        <span class="hidden sm:inline-block">{site.trustIndicators.responseTime}</span>
      </div>
      <a
        href={site.contact.phoneHref}
        class="font-bold tracking-wider uppercase text-accent-400 hover:text-accent-300"
      >
        Call {site.contact.phone}
      </a>
    </div>
  </div>

  <div class="max-w-container mx-auto px-4">
    <div class="flex items-center justify-between h-16 lg:h-20">
      <a href="/" class="flex items-center gap-3 focus-ring" aria-label={`${site.name} home`}>
        {logoConfig.style === 'icon-text' && (
          <>
            {logoConfig.icon_src && (
              <img src={logoConfig.icon_src} alt={logoConfig.alt} class={logoSizeClass} />
            )}
            {logoConfig.show_text !== false && (
              <span class="font-heading font-bold text-base lg:text-lg text-primary-800 leading-tight uppercase tracking-tight">
                {site.shortName ? (
                  <>
                    Toronto<br class="hidden lg:block" /> Basement Underpinning
                  </>
                ) : (
                  site.name
                )}
              </span>
            )}
          </>
        )}
        {logoConfig.style === 'text-only' && (
          <span class="font-heading font-bold text-lg text-primary-800 uppercase">{site.name}</span>
        )}
      </a>

      <nav class="hidden lg:flex items-center gap-7" aria-label="Main navigation">
        {menu.map((item) => (
          item.children && item.children.length > 0 ? (
            <div class="relative group">
              <a
                href={item.href}
                class="font-heading text-sm font-bold uppercase tracking-wider text-brand-text hover:text-accent-500 transition-colors focus-ring flex items-center gap-1"
              >
                {item.label}
                <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
                </svg>
              </a>
              <div class="absolute top-full left-0 pt-2 opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all duration-200 z-50">
                <div class="bg-white border border-brand-border shadow-lg py-2 min-w-56">
                  {item.children.map((child) => (
                    <a
                      href={child.href}
                      class="block px-4 py-2.5 text-sm text-brand-text hover:bg-primary-50 hover:text-accent-600 transition-colors"
                    >
                      {child.label}
                    </a>
                  ))}
                </div>
              </div>
            </div>
          ) : (
            <a
              href={item.href}
              class="font-heading text-sm font-bold uppercase tracking-wider text-brand-text hover:text-accent-500 transition-colors focus-ring"
            >
              {item.label}
            </a>
          )
        ))}
      </nav>

      <div class="hidden lg:flex items-center gap-4">
        <a href={cta.href} class="btn btn-primary text-xs">
          {cta.label}
        </a>
      </div>

      <button
        id="mobile-menu-toggle"
        type="button"
        class="lg:hidden p-2 text-primary-800 focus-ring"
        aria-label="Toggle menu"
        aria-expanded="false"
        aria-controls="mobile-menu"
      >
        <svg id="menu-icon-open" class="w-7 h-7" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
        </svg>
        <svg id="menu-icon-close" class="w-7 h-7 hidden" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
        </svg>
      </button>
    </div>
  </div>

  <nav
    id="mobile-menu"
    class="lg:hidden hidden bg-primary-800 border-t border-primary-700"
    aria-label="Mobile navigation"
  >
    <div class="max-w-container mx-auto px-4 py-4 space-y-1">
      {menu.map((item, idx) => (
        item.children && item.children.length > 0 ? (
          <div>
            <button
              type="button"
              class="mobile-menu-parent flex items-center justify-between w-full py-3 px-4 text-white hover:bg-primary-700 font-heading uppercase tracking-wider text-sm font-bold"
              data-submenu={`submenu-${idx}`}
              aria-expanded="false"
            >
              <span>{item.label}</span>
              <svg class="mobile-menu-item-toggle w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
              </svg>
            </button>
            <div id={`submenu-${idx}`} class="mobile-submenu pl-4">
              {item.children.map((child) => (
                <a
                  href={child.href}
                  class="block py-2.5 px-4 text-primary-100 hover:bg-primary-700 hover:text-white text-sm"
                >
                  {child.label}
                </a>
              ))}
            </div>
          </div>
        ) : (
          <a
            href={item.href}
            class="block py-3 px-4 text-white hover:bg-primary-700 font-heading uppercase tracking-wider text-sm font-bold"
          >
            {item.label}
          </a>
        )
      ))}
      <div class="pt-4 border-t border-primary-700 mt-4 space-y-3">
        <a
          href={site.contact.phoneHref}
          class="flex items-center justify-center gap-2 w-full py-3 border-2 border-white text-white font-heading uppercase tracking-wider text-sm font-bold"
        >
          {site.contact.phone}
        </a>
        <a
          href={cta.href}
          class="flex items-center justify-center gap-2 w-full py-3 bg-accent-500 text-white font-heading uppercase tracking-wider text-sm font-bold"
        >
          {cta.label}
        </a>
      </div>
    </div>
  </nav>
</header>

<script>
  const toggle = document.getElementById('mobile-menu-toggle');
  const menu = document.getElementById('mobile-menu');
  const iconOpen = document.getElementById('menu-icon-open');
  const iconClose = document.getElementById('menu-icon-close');

  toggle?.addEventListener('click', () => {
    const isHidden = menu?.classList.toggle('hidden');
    toggle.setAttribute('aria-expanded', String(!isHidden));
    iconOpen?.classList.toggle('hidden');
    iconClose?.classList.toggle('hidden');
  });

  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape' && !menu?.classList.contains('hidden')) {
      menu?.classList.add('hidden');
      toggle?.setAttribute('aria-expanded', 'false');
      iconOpen?.classList.remove('hidden');
      iconClose?.classList.add('hidden');
    }
  });

  document.querySelectorAll<HTMLButtonElement>('.mobile-menu-parent').forEach((btn) => {
    btn.addEventListener('click', () => {
      const submenuId = btn.getAttribute('data-submenu');
      if (!submenuId) return;
      const submenu = document.getElementById(submenuId);
      const icon = btn.querySelector('.mobile-menu-item-toggle');

      document.querySelectorAll<HTMLElement>('.mobile-submenu.open').forEach((s) => {
        if (s.id !== submenuId) {
          s.classList.remove('open');
          const sibling = document.querySelector<HTMLButtonElement>(`[data-submenu="${s.id}"]`);
          sibling?.setAttribute('aria-expanded', 'false');
          sibling?.querySelector('.mobile-menu-item-toggle')?.classList.remove('open');
        }
      });

      const isOpen = submenu?.classList.toggle('open');
      icon?.classList.toggle('open');
      btn.setAttribute('aria-expanded', String(Boolean(isOpen)));
    });
  });
</script>
