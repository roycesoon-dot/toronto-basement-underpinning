            <a href={`/${rs.slug}/`} class="block tbu-card p-6 relative group focus-ring">
              <span class="corner-bracket"></span>
              <h3 class="text-lg mb-3 leading-tight group-hover:text-accent-500 transition-colors">{rs.data.title}</h3>
              <p class="text-sm text-brand-muted leading-relaxed">{rs.data.description}</p>
              <span class="block mt-4 text-xs font-bold uppercase tracking-widest text-accent-500">Learn More &rarr;</span>
            </a>
          ))}
        </div>
      </div>
    </section>
  )}

  <CTA
    headline={`Ready For ${service.data.shortTitle}?`}
    subheadline="Free engineered estimate within two business hours."
  />
</BaseLayout>
