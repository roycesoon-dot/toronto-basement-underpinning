---
import { getCollection, getEntry } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import TrustBar from '../components/blocks/TrustBar.astro';
import Testimonials from '../components/blocks/Testimonials.astro';
import FAQ from '../components/blocks/FAQ.astro';
import CTA from '../components/blocks/CTA.astro';
import Callout from '../components/ui/Callout.astro';
import ContentImage from '../components/ui/ContentImage.astro';
import site from '../config/site.json';

export async function getStaticPaths() {
  const services = await getCollection('services');
  return services.map((service) => ({
    params: { slug: service.slug },
    props: { service },
  }));
}

const { service } = Astro.props;
const { Content } = await service.render();

const meta = service.data.seo?.metaTitle || `${service.data.title} Toronto | ${site.name}`;
const description = service.data.seo?.metaDescription || service.data.description;
const h1 = service.data.h1Title || `Professional ${service.data.title} in Toronto`;

const formattedUpdated = service.data.lastUpdated
  ? new Date(service.data.lastUpdated).toLocaleDateString('en-CA', { year: 'numeric', month: 'long', day: 'numeric' })
  : null;

// Look up related services
const allServices = await getCollection('services');
const relatedSlugs = service.data.relatedServices || [];
const relatedServices = allServices.filter((s) => relatedSlugs.includes(s.slug));

const serviceSchema = {
  '@context': 'https://schema.org',
  '@type': 'Service',
  '@id': `${site.url}/${service.slug}/#service`,
  name: service.data.title,
  description: service.data.description,
  provider: { '@id': `${site.url}/#organization` },
  serviceType: service.data.title,
  areaServed: {
    '@type': 'City',
    name: site.address.city,
    containedInPlace: { '@type': 'State', name: 'Ontario' },
  },
  ...(service.data.pricing && {
    offers: {
      '@type': 'Offer',
      price: service.data.pricing.from,
      priceCurrency: 'CAD',
      ...(service.data.pricing.to && {
        priceSpecification: {
          '@type': 'PriceSpecification',
          minPrice: service.data.pricing.from,
          maxPrice: service.data.pricing.to,
          priceCurrency: 'CAD',
        },
      }),
    },
  }),
};

const breadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: site.url + '/' },
    { '@type': 'ListItem', position: 2, name: service.data.title, item: `${site.url}/${service.slug}/` },
  ],
};

const howToSchema = service.data.process && service.data.process.length > 0
  ? {
      '@context': 'https://schema.org',
      '@type': 'HowTo',
      name: `How ${service.data.shortTitle || service.data.title} Works`,
      description: `Our professional ${service.data.shortTitle || service.data.title} process in Toronto.`,
      step: service.data.process.map((p: { step: number; title: string; description: string }) => ({
        '@type': 'HowToStep',
        name: p.title,
        text: p.description,
        position: p.step,
      })),
    }
  : null;
---

<BaseLayout title={meta} description={description} image={service.data.image} pageType="service_pages">
  <script type="application/ld+json" set:html={JSON.stringify(serviceSchema)} slot="head" />
  <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} slot="head" />
  {howToSchema && <script type="application/ld+json" set:html={JSON.stringify(howToSchema)} slot="head" />}

  <section class="relative overflow-hidden bg-primary-800 text-white">
    <div class="absolute inset-0 z-0">
      <img src={service.data.image} alt="" class="w-full h-full object-cover" loading="eager" />
      <div class="absolute inset-0 bg-gradient-to-r from-primary-800/95 via-primary-800/80 to-primary-700/55"></div>
    </div>
    <div class="relative z-10 max-w-container mx-auto px-4 py-14 lg:py-24">
      <nav class="text-xs text-primary-200 mb-4 flex flex-wrap gap-1.5 items-center" aria-label="Breadcrumb">
        <a href="/" class="hover:text-accent-400">Home</a>
        <span class="text-primary-400">&rsaquo;</span>
        <span class="text-white">{service.data.title}</span>
      </nav>

      {service.data.badge && (
        <span class="inline-block bg-accent-500 text-white text-xs font-bold uppercase tracking-widest px-3 py-1.5 mb-4">
          {service.data.badge}
        </span>
      )}
      <h1 class="text-white mb-4 max-w-4xl">{h1}</h1>
      <span class="accent-bar"></span>
      <p class="text-lg text-primary-100 max-w-2xl mb-8">{service.data.description}</p>

      <div class="flex flex-wrap gap-3 mb-8">
        <a href="/contact/" class="btn btn-primary">Get a Free Estimate</a>
        <a href={site.contact.phoneHref} class="btn btn-outline-light">
          Call {site.contact.phone}
        </a>
      </div>

      {service.data.pricing && (
        <div class="text-sm text-primary-100">
          <span class="font-bold uppercase tracking-widest text-accent-400">Typical project:</span>
          <span class="ml-2 font-bold">
            {service.data.pricing.currency}{service.data.pricing.from?.toLocaleString()}
            {service.data.pricing.to ? `-${service.data.pricing.currency}${service.data.pricing.to.toLocaleString()}` : '+'}
          </span>
          {service.data.pricing.unit && <span class="ml-1 text-primary-200">{service.data.pricing.unit}</span>}
        </div>
      )}
      {formattedUpdated && (
        <p class="text-xs text-primary-300 mt-4">
          <time datetime={service.data.lastUpdated}>Last updated: {formattedUpdated}</time>
        </p>
      )}
    </div>
  </section>

  <TrustBar />

  <section class="py-16 lg:py-20 bg-white">
    <div class="max-w-container mx-auto px-4">
      <div class="lg:grid lg:grid-cols-[1fr_320px] lg:gap-10">
        <!-- Main Content -->
        <article class="prose-tbu">
          <Content components={{ Callout, ContentImage }} />
        </article>
        <!-- Sticky Sidebar -->
        <aside class="hidden lg:block">
          <div class="sticky top-24 space-y-4">

            {/* CARD 1: QUICK FACTS */}
            <div class="rounded-xl overflow-hidden" style="background-color: #1A2942;">
              <div class="px-5 pt-5 pb-4">
                <p class="text-xs font-bold uppercase tracking-widest mb-3" style="color: #FF7E21;">Quick Facts</p>
                <div class="space-y-2">
                  <div class="flex justify-between text-sm">
                    <span class="text-primary-200">Permit</span>
                    <span class="text-white font-medium text-right">City of Toronto Building Permit</span>
                  </div>
                  <div class="flex justify-between text-sm">
                    <span class="text-primary-200">Code</span>
                    <span class="text-white font-medium text-right">Ontario Building Code Section 9.13</span>
                  </div>
                  <div class="flex justify-between text-sm">
                    <span class="text-primary-200">Service Areas</span>
                    <span class="text-white font-medium text-right">Toronto, North York, Mississauga</span>
                  </div>
                  <div class="flex justify-between text-sm">
                    <span class="text-primary-200">Warranty</span>
                    <span class="text-white font-medium text-right">Zero-Risk Structural</span>
                  </div>
                </div>
              </div>
            </div>

            {/* CARD 2: US VS THEM */}
            <div class="rounded-xl bg-white border" style="border-color: #CBD5E0;">
              <div class="px-5 pt-5 pb-4">
                <p class="text-xs font-bold uppercase tracking-widest mb-3" style="color: #FF7E21;">Us vs Generic Renovator</p>
                <div class="space-y-2">
                  <div class="flex items-start gap-2 text-sm">
                    <svg class="w-4 h-4 text-green-500 flex-shrink-0 mt-0.5" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd" /></svg>
                    <span class="text-brand-text">Structural engineer + permits under one contract</span>
                  </div>
                  <div class="flex items-start gap-2 text-sm">
                    <svg class="w-4 h-4 text-green-500 flex-shrink-0 mt-0.5" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd" /></svg>
                    <span class="text-brand-text">20 dedicated crews on payroll</span>
                  </div>
                  <div class="flex items-start gap-2 text-sm">
                    <svg class="w-4 h-4 text-green-500 flex-shrink-0 mt-0.5" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd" /></svg>
                    <span class="text-brand-text">Single warranty covers entire scope</span>
                  </div>
                  <div class="flex items-start gap-2 text-sm">
                    <svg class="w-4 h-4 text-red-500 flex-shrink-0 mt-0.5" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M4.293 4.293a1 1 0 011.414 0L10 8.586l4.293-4.293a1 1 0 111.414 1.414L11.414 10l4.293 4.293a1 1 0 01-1.414 1.414L10 11.414l-4.293 4.293a1 1 0 01-1.414-1.414L8.586 10 4.293 5.707a1 1 0 010-1.414z" clip-rule="evenodd" /></svg>
                    <span class="text-brand-muted">Generic renovators sub out the structural piece</span>
                  </div>
                </div>
              </div>
            </div>

            {/* CARD 3: FREE ASSESSMENT */}
            <div class="rounded-xl overflow-hidden" style="background-color: #1A2942;">
              <div class="px-5 pt-5 pb-5">
                <p class="text-xs font-bold uppercase tracking-widest mb-2" style="color: #FF7E21;">Free Assessment</p>
                <h3 class="text-white text-lg font-bold mb-2">Free Assessment in Toronto</h3>
                <p class="text-primary-200 text-sm mb-4">Free on-site assessment + written fixed-price quote within 48 hours. Engineered drawings and permits included in scope.</p>
                <a href="/contact/" class="block text-center font-bold py-3 px-4 rounded-none transition-opacity" style="background-color: #FF7E21; color: white;">Request Free Estimate</a>
                <p class="text-primary-300 text-sm text-center mt-3">{site.contact.phone}</p>
              </div>
            </div>

            {/* CARD 4: WHAT'S INCLUDED — dynamic per service */}
            <div class="rounded-xl bg-white border" style="border-color: #CBD5E0;">
              <div class="px-5 pt-5 pb-4">
                <p class="text-xs font-bold uppercase tracking-widest mb-3" style="color: #FF7E21;">What's Included</p>
                <ul class="space-y-2">
                  {service.slug === 'interior-waterproofing' && (
                    <>
                      <li class="flex items-start gap-2 text-sm"><svg class="w-4 h-4 text-green-500 flex-shrink-0 mt-0.5" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd" /></svg><span class="text-brand-text">Weeping tile installation</span></li>
                      <li class="flex items-start gap-2 text-sm"><svg class="w-4 h-4 text-green-500 flex-shrink-0 mt-0.5" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd" /></svg><span class="text-brand-text">Sealed sump pit + primary pump</span></li>
                      <li class="flex items-start gap-2 text-sm"><svg class="w-4 h-4 text-green-500 flex-shrink-0 mt-0.5" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd" /></svg><span class="text-brand-text">Delta MS dimple membrane</span></li>
                      <li class="flex items-start gap-2 text-sm"><svg class="w-4 h-4 text-green-500 flex-shrink-0 mt-0.5" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd" /></svg><span class="text-brand-text">Slab saw-cut + restoration</span></li>
                      <li class="flex items-start gap-2 text-sm"><svg class="w-4 h-4 text-green-500 flex-shrink-0 mt-0.5" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd" /></svg><span class="text-brand-text">Battery backup sump pump</span></li>
                      <li class="flex items-start gap-2 text-sm"><svg class="w-4 h-4 text-green-500 flex-shrink-0 mt-0.5" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd" /></svg><span class="text-brand-text">Backwater valve install</span></li>
                      <li class="flex items-start gap-2 text-sm"><svg class="w-4 h-4 text-green-500 flex-shrink-0 mt-0.5" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd" /></svg><span class="text-brand-text">Dust isolation + site cleanup</span></li>
                      <li class="flex items-start gap-2 text-sm"><svg class="w-4 h-4 text-green-500 flex-shrink-0 mt-0.5" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd" /></svg><span class="text-brand-text">City inspection + warranty</span></li>
                    </>
                  )}
                  {service.slug === 'basement-finishing' && (
                    <>
                      <li class="flex items-start gap-2 text-sm"><svg class="w-4 h-4 text-green-500 flex-shrink-0 mt-0.5" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd" /></svg><span class="text-brand-text">Structural underpinning (if needed)</span></li>
                      <li class="flex items-start gap-2 text-sm"><svg class="w-4 h-4 text-green-500 flex-shrink-0 mt-0.5" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd" /></svg><span class="text-brand-text">Framing + insulation</span></li>
                      <li class="flex items-start gap-2 text-sm"><svg class="w-4 h-4 text-green-500 flex-shrink-0 mt-0.5" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd" /></svg><span class="text-brand-text">Electrical + plumbing rough-ins</span></li>
                      <li class="flex items-start gap-2 text-sm"><svg class="w-4 h-4 text-green-500 flex-shrink-0 mt-0.5" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd" /></svg><span class="text-brand-text">Drywall + mudding + primer</span></li>
                      <li class="flex items-start gap-2 text-sm"><svg class="w-4 h-4 text-green-500 flex-shrink-0 mt-0.5" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd" /></svg><span class="text-brand-text">Flooring + trim + fixtures</span></li>
                      <li class="flex items-start gap-2 text-sm"><svg class="w-4 h-4 text-green-500 flex-shrink-0 mt-0.5" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd" /></svg><span class="text-brand-text">OBC 9.36 legal apartment compliance</span></li>
                      <li class="flex items-start gap-2 text-sm"><svg class="w-4 h-4 text-green-500 flex-shrink-0 mt-0.5" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd" /></svg><span class="text-brand-text">Secondary suite registration</span></li>
                      <li class="flex items-start gap-2 text-sm"><svg class="w-4 h-4 text-green-500 flex-shrink-0 mt-0.5" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd" /></svg><span class="text-brand-text">Final inspection + warranty</span></li>
                    </>
                  )}
                  {service.slug === 'sump-pumps' && (
                    <>
                      <li class="flex items-start gap-2 text-sm"><svg class="w-4 h-4 text-green-500 flex-shrink-0 mt-0.5" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd" /></svg><span class="text-brand-text">High-volume primary pump sized for local water table</span></li>
                      <li class="flex items-start gap-2 text-sm"><svg class="w-4 h-4 text-green-500 flex-shrink-0 mt-0.5" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd" /></svg><span class="text-brand-text">Sealed Group 31 AGM battery backup</span></li>
                      <li class="flex items-start gap-2 text-sm"><svg class="w-4 h-4 text-green-500 flex-shrink-0 mt-0.5" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd" /></svg><span class="text-brand-text">Auto AC-DC switchover system</span></li>
                      <li class="flex items-start gap-2 text-sm"><svg class="w-4 h-4 text-green-500 flex-shrink-0 mt-0.5" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd" /></svg><span class="text-brand-text">Sealed pit lid + discharge line</span></li>
                      <li class="flex items-start gap-2 text-sm"><svg class="w-4 h-4 text-green-500 flex-shrink-0 mt-0.5" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd" /></svg><span class="text-brand-text">City permit + inspection</span></li>
                      <li class="flex items-start gap-2 text-sm"><svg class="w-4 h-4 text-green-500 flex-shrink-0 mt-0.5" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd" /></svg><span class="text-brand-text">Subsidy paperwork filed for you</span></li>
                      <li class="flex items-start gap-2 text-sm"><svg class="w-4 h-4 text-green-500 flex-shrink-0 mt-0.5" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd" /></svg><span class="text-brand-text">Backwater valve install</span></li>
                      <li class="flex items-start gap-2 text-sm"><svg class="w-4 h-4 text-green-500 flex-shrink-0 mt-0.5" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd" /></svg><span class="text-brand-text">Zero-risk warranty</span></li>
                    </>
                  )}
                  {service.slug === 'concrete-foundation-repair' && (
