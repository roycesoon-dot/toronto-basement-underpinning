---
import '../styles/global.css';
import Header from '../components/layout/Header.astro';
import Footer from '../components/layout/Footer.astro';
import site from '../config/site.json';

interface Props {
  title: string;
  description?: string;
  image?: string;
  type?: 'website' | 'article';
  pageType?: 'homepage' | 'service_pages' | 'location_pages' | 'blog_pages' | 'contact_page' | 'about_page' | 'guide_pages' | 'default';
  publishedTime?: string;
  modifiedTime?: string;
  noindex?: boolean;
}

const {
  title,
  description = site.tagline,
  image = '/images/featured/toronto-basement-underpinning-specialist-contracto.webp',
  type = 'website',
  publishedTime,
  modifiedTime,
  noindex = false,
} = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, Astro.site || site.url).toString();
const ogImage = image.startsWith('http') ? image : new URL(image, Astro.site || site.url).toString();

// GTM config (GTM ID from config or env var fallback)
const gtmId = '' || import.meta.env.PUBLIC_GTM_ID || '';
const headScripts = '';
const bodyScripts = '';
---

<!DOCTYPE html>
<html lang="en-CA">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <title>{title}</title>
    <meta name="title" content={title} />
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalURL} />
    {noindex && <meta name="robots" content="noindex, nofollow" />}

    <meta property="og:type" content={type} />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:site_name" content={site.name} />
    <meta property="og:locale" content="en_CA" />
    {publishedTime && <meta property="article:published_time" content={publishedTime} />}
    {modifiedTime && <meta property="article:modified_time" content={modifiedTime} />}

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:url" content={canonicalURL} />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />

    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="apple-touch-icon" href="/favicon.svg" />
    <link rel="manifest" href="/site.webmanifest" />

    <meta name="theme-color" content="#041627" />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    {/* Preload primary font for non-blocking load */}
    <link rel="preload" as="style" href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Work+Sans:wght@600;700;800;900&display=swap" onload="this.rel='stylesheet'" />
    <noscript><link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Work+Sans:wght@600;700;800;900&display=swap" /></noscript>

    {/* Generator tag removed — avoids leaking framework version to crawlers */}
    <slot name="head" />

    {/* Google Tag Manager - Deferred loading (non-blocking) */}
    {gtmId && (
      <script is:inline define:vars={{ gtmId }}>
        function loadGTM() {
          if (window.gtmLoaded) return;
          window.gtmLoaded = true;
          (function(w,d,s,l,i){w[l]=w[l]||[];w[l].push({'gtm.start':
          new Date().getTime(),event:'gtm.js'});var f=d.getElementsByTagName(s)[0],
          j=d.createElement(s),dl=l!='dataLayer'?'&l='+l:'';j.async=true;j.src=
          'https://www.googletagmanager.com/gtm.js?id='+i+dl;f.parentNode.insertBefore(j,f);
          })(window,document,'script','dataLayer', gtmId);
        }
        ['scroll','click','touchstart','keydown'].forEach(e =>
          window.addEventListener(e, loadGTM, {once:true, passive:true})
        );
        setTimeout(loadGTM, 3000);
      </script>
    )}

    {/* Custom Head Scripts */}
    {headScripts && (
      <Fragment set:html={headScripts} />
    )}

    <style>
      /* Force VAPI widget to bottom-left */
      div[id^="vapi"],
      div[class*="vapi"],
      #vapi-support-btn,
      .vapi-btn {
        position: fixed !important;
        bottom: 24px !important;
        left: 24px !important;
        top: auto !important;
        right: auto !important;
        z-index: 9999 !important;
      }
    </style>
  </head>
  <body class="bg-brand-bg text-brand-text font-body antialiased overflow-x-hidden">
    <a href="#main-content" class="skip-link focus:outline-none">Skip to main content</a>
    <Header />

    {/* Google Tag Manager noscript fallback */}
    {gtmId && (
      <noscript>
        <iframe
          src={`https://www.googletagmanager.com/ns.html?id=${gtmId}`}
          height="0"
          width="0"
          style="display:none;visibility:hidden"
        />
      </noscript>
    )}

    {/* Custom Body Scripts */}
    {bodyScripts && (
      <Fragment set:html={bodyScripts} />
    )}

    <main id="main-content" tabindex="-1">
      <slot />
    </main>
    <Footer />

    {/* Back to Top Button */}
    <button
      id="back-to-top"
      aria-label="Back to top"
      class="fixed bottom-8 right-8 w-12 h-12 rounded-full bg-[#FF7E21] text-white shadow-lg flex items-center justify-center opacity-0 pointer-events-none transition-opacity duration-300 z-50 hover:bg-[#e06d1a] focus:outline-none focus:ring-2 focus:ring-[#FF7E21] focus:ring-offset-2"
    >
      <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <path d="M18 15l-6-6-6 6"/>
      </svg>
    </button>

    <script is:inline>
      (function() {
        var btn = document.getElementById('back-to-top');
        if (!btn) return;
        function toggleBackToTop() {
          if (window.scrollY > 400) {
            btn.classList.remove('opacity-0', 'pointer-events-none');
            btn.classList.add('opacity-100');
          } else {
            btn.classList.add('opacity-0', 'pointer-events-none');
            btn.classList.remove('opacity-100');
          }
        }
        window.addEventListener('scroll', toggleBackToTop, { passive: true });
        btn.addEventListener('click', function() {
          window.scrollTo({ top: 0, behavior: 'smooth' });
        });
        toggleBackToTop();
      })();
    </script>

    <!-- VAPI Voice Agent Widget — Toronto Basement Underpinning -->
    <script is:inline>
      (function (d, t) {
        var g = document.createElement(t), s = d.getElementsByTagName(t)[0];
        g.src = "https://cdn.jsdelivr.net/gh/VapiAI/html-script-tag@latest/dist/assets/index.js";
        g.defer = true; g.async = true;
        s.parentNode.insertBefore(g, s);
        g.onload = function () {
          window.vapiSDK.run({
            apiKey: "9420dbcf-2d1a-4b89-8679-e48a0bb9ee10",
            assistant: "b1fb5bb8-f401-4eaf-877d-8fa235a55ee0",
            config: {
              position: "bottom-left",
              offset: "24px",
              width: "56px",
              height: "56px",
              idle: {
                color: "#FF7E21",
                type: "round",
                icon: "https://unpkg.com/lucide-static@0.321.0/icons/phone.svg",
              },
              loading: { color: "#FF7E21", type: "round" },
              active: {
                color: "#DC2626",
                type: "round",
                icon: "https://unpkg.com/lucide-static@0.321.0/icons/phone-off.svg",
              },
            },
          });
        };
      })(document, "script");
    </script>

    <script is:inline>
      (function () {
        function rescueVapi() {
          var vapiEl = document.querySelector(
            'button[id*="vapi"], div[id*="vapi"], button[class*="vapi"], div[class*="vapi"], #vapi-support-btn'
          );
          if (!vapiEl) return;
          var root = vapiEl;
          while (root.parentElement && root.parentElement !== document.body) {
            root = root.parentElement;
          }
          if (root.parentElement === document.body) {
            root.style.setProperty('position', 'fixed', 'important');
            root.style.setProperty('bottom', '24px', 'important');
            root.style.setProperty('left', '24px', 'important');
            root.style.setProperty('top', 'auto', 'important');
            root.style.setProperty('right', 'auto', 'important');
            root.style.setProperty('z-index', '99999', 'important');
          } else {
            document.body.appendChild(root);
            root.style.setProperty('position', 'fixed', 'important');
            root.style.setProperty('bottom', '24px', 'important');
            root.style.setProperty('left', '24px', 'important');
            root.style.setProperty('top', 'auto', 'important');
            root.style.setProperty('right', 'auto', 'important');
            root.style.setProperty('z-index', '99999', 'important');
          }
        }
        var done = false;
        var obs = new MutationObserver(function () {
          if (done) return;
          var el = document.querySelector('button[id*="vapi"], div[id*="vapi"], #vapi-support-btn, button[class*="vapi"]');
          if (el) { done = true; obs.disconnect(); setTimeout(rescueVapi, 300); }
        });
        obs.observe(document.body, { childList: true, subtree: true });
        window.addEventListener('load', rescueVapi);
        setTimeout(rescueVapi, 3000);
      })();
    </script>
</body>
</html>
