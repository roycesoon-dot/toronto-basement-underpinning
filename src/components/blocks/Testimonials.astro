---
interface Testimonial {
  quote: string;
  name?: string;
  author?: string;
  rating?: number;
  location?: string;
  service?: string;
}

interface Props {
  items: Testimonial[];
  title?: string;
  subtitle?: string;
}

const { items, title = 'What Toronto Homeowners Say', subtitle } = Astro.props;
---

<section class="py-16 lg:py-20 bg-white">
  <div class="max-w-container mx-auto px-4">
    <div class="text-center mb-12">
      <span class="section-label">Testimonials</span>
      <h2 class="mt-3">{title}</h2>
      <span class="accent-bar accent-bar-center"></span>
      {subtitle && <p class="text-brand-muted max-w-2xl mx-auto">{subtitle}</p>}
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
      {items.map((t) => (
        <article class="tbu-card p-6 relative">
          <span class="corner-bracket"></span>
          <div class="flex text-accent-500 mb-3" aria-label={`${t.rating || 5} out of 5 stars`}>
            {Array.from({ length: t.rating || 5 }).map(() => (
              <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" /></svg>
            ))}
          </div>
          <p class="text-brand-text leading-relaxed mb-5">&ldquo;{t.quote}&rdquo;</p>
          <div class="border-t border-brand-border pt-4">
            <p class="font-heading font-bold uppercase tracking-tight text-sm text-primary-800">
              {t.name || t.author}
            </p>
            {t.location && <p class="text-xs text-brand-muted mt-1">{t.location}</p>}
          </div>
        </article>
      ))}
    </div>
  </div>
</section>
