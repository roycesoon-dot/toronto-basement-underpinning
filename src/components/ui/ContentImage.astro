---
interface Props {
  src: string;
  alt: string;
  caption?: string;
}
const { src, alt, caption } = Astro.props;
---

<figure class="my-8 max-w-2xl mx-auto">
  <img src={src} alt={alt} class="w-full rounded-lg" loading="lazy" />
  {caption && (
    <figcaption class="text-center text-sm text-brand-muted mt-2 italic">
      {caption}
    </figcaption>
  )}
</figure>
