---
import BaseLayout from '../layouts/BaseLayout.astro';
import TrustBar from '../components/blocks/TrustBar.astro';
import Testimonials from '../components/blocks/Testimonials.astro';
import Stats from '../components/blocks/Stats.astro';
import FAQ from '../components/blocks/FAQ.astro';
import CTA from '../components/blocks/CTA.astro';
import { getCollection } from 'astro:content';
import site from '../config/site.json';
import faqData from '../config/faq.json';
import locations from '../config/locations.json';

const services = (await getCollection('services')).sort((a, b) => {
  if (a.data.featured && !b.data.featured) return -1;
  if (!a.data.featured && b.data.featured) return 1;
  return 0;
});

const featuredFaqs = faqData.filter((f) => f.featured).slice(0, 6);

const heroImage = "/images/misc/toronto-basement-underpinning-specialists-staged-e.webp";

const primaryLocations = locations.filter((l) => l.type === 'primary');

const torontoCoords = { lat: 43.6532, lng: -79.3832 };

const dayOfWeekLookup: Record<string, string | string[]> = {
  weekdays: ['Monday', 'Tuesday', 'Wednesday', 'Thursday', 'Friday'],
  saturday: 'Saturday',
  sunday: 'Sunday',
};

const wikidataCityLookup: Record<string, string> = {
  toronto: 'https://www.wikidata.org/wiki/Q172',
  'north-york': 'https://www.wikidata.org/wiki/Q377396',
  etobicoke: 'https://www.wikidata.org/wiki/Q1066807',
  scarborough: 'https://www.wikidata.org/wiki/Q1064953',
  mississauga: 'https://www.wikidata.org/wiki/Q174583',
  brampton: 'https://www.wikidata.org/wiki/Q160642',
  markham: 'https://www.wikidata.org/wiki/Q500960',
  vaughan: 'https://www.wikidata.org/wiki/Q500898',
  'richmond-hill': 'https://www.wikidata.org/wiki/Q523850',
  oakville: 'https://www.wikidata.org/wiki/Q500940',
  burlington: 'https://www.wikidata.org/wiki/Q500948',
  pickering: 'https://www.wikidata.org/wiki/Q505263',
};

const openingHoursSpec = Object.entries(site.schema.openingHours)
  .filter(([, hours]) => hours !== 'Closed')
  .map(([dayKey, hours]) => ({
    '@type': 'OpeningHoursSpecification',
    dayOfWeek: dayOfWeekLookup[dayKey] ?? dayKey,
    opens: hours.split('-')[0],
    closes: hours.split('-')[1],
  }));

const orgSchema = {
  '@context': 'https://schema.org',
  '@type': site.schema.type,
  '@id': `${site.url}/#organization`,
  additionalType: 'https://www.wikidata.org/wiki/Q1077857',
  name: site.name,
  url: site.url,
  telephone: site.contact.phone,
  email: site.contact.email,
  description: site.tagline,
  image: `${site.url}${heroImage}`,
  logo: {
    '@type': 'ImageObject',
    '@id': `${site.url}/#logo`,
    url: `${site.url}/favicon.svg`,
  },
  address: {
    '@type': 'PostalAddress',
    addressLocality: site.address.city,
    addressRegion: site.address.state,
    addressCountry: site.address.country,
  },
  geo: {
    '@type': 'GeoCoordinates',
    latitude: torontoCoords.lat,
    longitude: torontoCoords.lng,
  },
  priceRange: '$$$',
  areaServed: locations.map((loc) => ({
    '@type': 'City',
    name: loc.name,
    containedInPlace: { '@type': 'State', name: 'Ontario' },
    ...(wikidataCityLookup[loc.slug] && { sameAs: wikidataCityLookup[loc.slug] }),
  })),
  serviceArea: {
    '@type': 'GeoCircle',
    geoMidpoint: {
      '@type': 'GeoCoordinates',
      latitude: torontoCoords.lat,
      longitude: torontoCoords.lng,
    },
    geoRadius: { '@type': 'Distance', value: String(site.schema.serviceRadiusKm), unitCode: 'KMT' },
  },
  knowsAbout: site.schema.knowsAbout,
  paymentAccepted: site.schema.paymentAccepted,
  openingHoursSpecification: openingHoursSpec,
  hasCredential: site.schema.credentials.map((c) => ({
    '@type': 'EducationalOccupationalCredential',
    credentialCategory: 'Professional License',
    name: c,
  })),
  hasOfferCatalog: {
    '@type': 'OfferCatalog',
    name: 'Services',
    itemListElement: services.map((s) => ({
      '@type': 'Offer',
      itemOffered: {
        '@type': 'Service',
        '@id': `${site.url}/${s.slug}/#service`,
        name: s.data.title,
      },
    })),
  },
  aggregateRating: {
    '@type': 'AggregateRating',
    ratingValue: site.trustIndicators.rating,
    reviewCount: '49',
    bestRating: '5',
  },
};

const websiteSchema = {
  '@context': 'https://schema.org',
  '@type': 'WebSite',
  '@id': `${site.url}/#website`,
  name: site.name,
  url: site.url,
  publisher: { '@id': `${site.url}/#organization` },
};
---

<BaseLayout
  title={`${site.name} | Toronto's #1 Underpinning Specialists`}
  description={site.tagline}
  pageType="homepage"
>
  <script type="application/ld+json" set:html={JSON.stringify(orgSchema)} slot="head" />
  <script type="application/ld+json" set:html={JSON.stringify(websiteSchema)} slot="head" />

  <section class="relative overflow-hidden bg-primary-800 text-white">
    <div class="absolute inset-0 z-0">
      <img src={heroImage} alt="" class="w-full h-full object-cover" loading="eager" />
      <div class="absolute inset-0 bg-gradient-to-r from-primary-800/95 via-primary-800/85 to-primary-800/55"></div>
    </div>
    <div class="relative z-10 max-w-container mx-auto px-4 py-16 lg:py-28">
      <div class="grid lg:grid-cols-12 gap-10 items-center">
        <div class="lg:col-span-7">
          <div class="inline-flex items-center gap-2 bg-accent-500/20 border border-accent-500 px-3 py-1.5 mb-5">
            <span class="flex h-2 w-2 rounded-full bg-accent-400 animate-pulse"></span>
            <span class="text-xs font-bold uppercase tracking-widest text-accent-300">
              Free Estimate Within 2 Hours
            </span>
          </div>
          <h1 class="text-white mb-5 leading-[1.05]">
            Toronto's Highest-Volume Basement<br /><span class="text-accent-400">Underpinning Specialists</span>
          </h1>
          <span class="accent-bar"></span>
          <p class="text-lg lg:text-xl text-primary-100 mb-3 max-w-xl">
            20 dedicated crews. Drawings, permits, lowering, waterproofing, and finishing. All under one roof.
          </p>
          <p class="text-base text-primary-200 mb-8 max-w-xl">
            Add livable square footage. Build a legal apartment. Fix a real structural problem. Backed by our zero-risk, no-questions-asked warranty.
          </p>

          <div class="flex flex-wrap gap-3 mb-8">
            <a href="/contact/" class="btn btn-primary">Get a Free Estimate</a>
            <a href={site.contact.phoneHref} class="btn btn-outline-light">
              Call {site.contact.phone}
            </a>
          </div>

          <div class="flex flex-wrap gap-x-6 gap-y-3 text-sm text-primary-100">
            <span class="flex items-center gap-2">
              <svg class="w-5 h-5 text-accent-400" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd" /></svg>
              Licensed &amp; Insured
            </span>
            <span class="flex items-center gap-2">
              <svg class="w-5 h-5 text-accent-400" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd" /></svg>
              20+ Years Specialty
            </span>
            <span class="flex items-center gap-2">
              <svg class="w-5 h-5 text-accent-400" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd" /></svg>
              Engineered Drawings &amp; Permits Included
            </span>
            <span class="flex items-center gap-2">
              <svg class="w-5 h-5 text-accent-400" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd" /></svg>
              Typical Project: $20,000-$50,000
            </span>
          </div>
        </div>

        <div class="lg:col-span-5">
          <div class="relative bg-white text-brand-text p-8 max-w-md ml-auto">
            <span class="corner-bracket"></span>
            <h3 class="text-lg mb-1">Free Estimate</h3>
            <p class="text-sm text-brand-muted mb-6">Typical response within two business hours.</p>
            <form action="https://formsubmit.co/roycc77@gmail.com" method="POST" class="space-y-3">
              <input type="hidden" name="_subject" value="New Lead - Toronto Basement Underpinning" />
              <input type="hidden" name="_captcha" value="false" />
              <input type="hidden" name="_next" value="https://torontobasementunderpinning.ca/" />
              <label for="hero-name" class="sr-only">Your Name</label>
              <input id="hero-name" type="text" name="name" required placeholder="Your Name" class="w-full px-4 py-3 border border-brand-border focus:border-accent-500 focus:outline-none text-base" />
              <label for="hero-phone" class="sr-only">Phone Number</label>
              <input id="hero-phone" type="tel" name="phone" required placeholder="Phone Number" class="w-full px-4 py-3 border border-brand-border focus:border-accent-500 focus:outline-none text-base" />
              <label for="hero-email" class="sr-only">Email</label>
              <input id="hero-email" type="email" name="email" placeholder="Email" class="w-full px-4 py-3 border border-brand-border focus:border-accent-500 focus:outline-none text-base" />
              <label for="hero-message" class="sr-only">Tell us about your basement project</label>
              <textarea id="hero-message" name="message" rows="3" placeholder="Tell us about your basement project" class="w-full px-4 py-3 border border-brand-border focus:border-accent-500 focus:outline-none text-base"></textarea>
              <button type="submit" class="btn btn-primary w-full">Get Free Estimate</button>
            </form>
            <p class="mt-4 text-xs text-brand-muted text-center">
              Or call directly: <a href={site.contact.phoneHref} class="text-accent-500 font-bold">{site.contact.phone}</a>
            </p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <TrustBar />

  <section class="py-16 lg:py-20 bg-white">
    <div class="max-w-container mx-auto px-4">
      <div class="text-center mb-12">
        <span class="section-label">Common Problems</span>
        <h2 class="mt-3">Basement Problems Toronto Homeowners Know Too Well</h2>
        <span class="accent-bar accent-bar-center"></span>
        <p class="text-brand-muted max-w-2xl mx-auto">
          The Toronto homeowners we work with are usually wrestling with one of these. We solve them properly, not with a quick fix that fails in two years.
        </p>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-5">
        <div class="tbu-card p-6 relative">
          <span class="corner-bracket"></span>
          <h3 class="text-lg mb-2">Cramped Ceiling Height</h3>
          <p class="text-brand-muted text-sm leading-relaxed">
            Your basement ceiling is under 7 feet, finishing the space feels claustrophobic, and a legal apartment is impossible at that height.
          </p>
        </div>
        <div class="tbu-card p-6 relative">
          <span class="corner-bracket"></span>
          <h3 class="text-lg mb-2">Cracked Foundation Walls</h3>
          <p class="text-brand-muted text-sm leading-relaxed">
            Recurring or stair-step cracks signal active settlement. Patches keep failing because the underlying bearing problem continues.
          </p>
        </div>
        <div class="tbu-card p-6 relative">
          <span class="corner-bracket"></span>
          <h3 class="text-lg mb-2">Leaking Basement</h3>
          <p class="text-brand-muted text-sm leading-relaxed">
            Water at the wall-floor cove every spring. The original weeping tile is clogged, cracked, or just aged out.
          </p>
        </div>
        <div class="tbu-card p-6 relative">
          <span class="corner-bracket"></span>
          <h3 class="text-lg mb-2">Stalled By Permits</h3>
          <p class="text-brand-muted text-sm leading-relaxed">
            The City of Toronto building permit, structural engineering, and Committee of Adjustment process feels like a maze.
          </p>
        </div>
      </div>
      <div class="text-center mt-10">
        <p class="text-base mb-3">Address all four with one project, one warranty, one project manager.</p>
        <a href="/contact/" class="btn btn-secondary">Get a Free Engineered Assessment</a>
      </div>
    </div>
  </section>

  <section class="py-16 lg:py-20 bg-brand-bg" id="services">
    <div class="max-w-container mx-auto px-4">
      <div class="text-center mb-12">
        <span class="section-label">Our Services</span>
        <h2 class="mt-3">Turnkey Basement Lowering &amp; Finishing Services in Toronto</h2>
        <span class="accent-bar accent-bar-center"></span>
        <p class="text-brand-muted max-w-2xl mx-auto">
          Underpinning is the structural backbone. Most projects bundle waterproofing, sump pumps, drawings, and finishing into one continuous job.
        </p>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
        {services.map((s) => (
          <a
            href={`/${s.slug}/`}
            class="block group bg-white border border-brand-border hover:border-accent-500 transition-colors relative focus-ring"
          >
            <span class="corner-bracket"></span>
            <div class="aspect-[4/3] overflow-hidden bg-primary-800">
              <img
                src={s.data.image}
                alt={s.data.title}
                class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
                loading="lazy"
              />
            </div>
            <div class="p-6">
              {s.data.badge && (
                <span class="inline-block bg-accent-500 text-white text-xs font-bold uppercase tracking-widest px-2 py-1 mb-3">
                  {s.data.badge}
                </span>
              )}
              <h3 class="text-lg mb-3 leading-tight">{s.data.title}</h3>
              <p class="text-sm text-brand-muted leading-relaxed mb-4">{s.data.description}</p>
              {s.data.pricing && (
                <p class="text-xs font-bold uppercase tracking-widest text-accent-500 mb-2">
                  {s.data.pricing.currency}{s.data.pricing.from?.toLocaleString()}
                  {s.data.pricing.to ? `-${s.data.pricing.currency}${s.data.pricing.to.toLocaleString()}` : '+'}
                </p>
              )}
              <span class="text-sm font-bold uppercase tracking-widest text-primary-800 group-hover:text-accent-500 transition-colors">
                Learn More &rarr;
              </span>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <section class="py-16 lg:py-20 bg-white">
    <div class="max-w-container mx-auto px-4">
      <div class="grid lg:grid-cols-2 gap-12 items-start">
        <div>
          <span class="section-label">Why Choose Us</span>
          <h2 class="mt-3 mb-2">Built For Toronto Homeowners</h2>
          <span class="accent-bar"></span>
          <p class="text-brand-muted mb-6 leading-relaxed">
            20+ years specializing in Toronto basement underpinning. 20 active crews — the largest dedicated underpinning workforce in the GTA. Drawings, permits, structural engineering, waterproofing, and finishing all coordinated in-house.
          </p>
          <div class="grid sm:grid-cols-2 gap-5">
            <div>
              <h3 class="text-base mb-2">20 Active Crews</h3>
              <p class="text-sm text-brand-muted">Most Toronto specialists quote 6+ months out. Our scheduling capacity means weeks, not months.</p>
            </div>
            <div>
              <h3 class="text-base mb-2">Turnkey Scope</h3>
              <p class="text-sm text-brand-muted">Architect, engineer, City of Toronto plan review, excavation, waterproofing, finishing — one team, one quote.</p>
            </div>
            <div>
              <h3 class="text-base mb-2">Engineer Stamp Standard</h3>
              <p class="text-sm text-brand-muted">Every project carries an engineered design from an Ontario-licensed structural engineer. No improvisation.</p>
            </div>
            <div>
              <h3 class="text-base mb-2">Zero-Risk Warranty</h3>
              <p class="text-sm text-brand-muted">If something covered fails, we return and resolve it. No contract scavenger hunt.</p>
            </div>
          </div>
        </div>
        <div class="grid grid-cols-2 gap-3">
          <img
            src="/images/misc/toronto-underpinning-crew-pouring-pin-section-at-s.webp"
            alt="Toronto underpinning crew pouring an engineered pin section"
            class="w-full aspect-square object-cover"
            loading="lazy"
          />
          <img
            src="/images/misc/engineered-drawings-being-reviewed-at-toronto-job-.webp"
            alt="Engineered drawings being reviewed at a Toronto basement underpinning site"
            class="w-full aspect-square object-cover mt-8"
            loading="lazy"
          />
          <img
            src="/images/misc/finished-toronto-basement-suite-index.webp"
            alt="A finished Toronto basement suite after underpinning"
            class="w-full aspect-square object-cover -mt-8"
            loading="lazy"
          />
          <img
            src="/images/misc/toronto-basement-underpinning-excavation-with-stag.webp"
            alt="Toronto basement excavation showing staged pin-section sequence"
            class="w-full aspect-square object-cover"
            loading="lazy"
          />
        </div>
      </div>
    </div>
  </section>

  <section class="py-16 lg:py-20 bg-brand-bg">
    <div class="max-w-container mx-auto px-4">
      <div class="text-center mb-12">
        <span class="section-label">How It Works</span>
        <h2 class="mt-3">How Toronto Basement Underpinning Works</h2>
        <span class="accent-bar accent-bar-center"></span>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-4 gap-5">
        <div class="process-card">
          <div class="text-xs font-bold uppercase tracking-widest text-accent-500 mb-2">Step 1</div>
          <h3 class="text-base mb-2">Free Site Visit</h3>
          <p class="text-sm text-brand-muted">Engineered assessment on your property. Fixed-price quote within two business hours.</p>
        </div>
        <div class="process-card process-card-accent">
          <div class="text-xs font-bold uppercase tracking-widest text-accent-500 mb-2">Step 2</div>
          <h3 class="text-base mb-2">Drawings &amp; Permits</h3>
          <p class="text-sm text-brand-muted">Architect, engineer, City of Toronto submission. We handle every form and every hearing.</p>
        </div>
        <div class="process-card">
          <div class="text-xs font-bold uppercase tracking-widest text-accent-500 mb-2">Step 3</div>
          <h3 class="text-base mb-2">Staged Construction</h3>
          <p class="text-sm text-brand-muted">Pin-section excavation and pours. Daily site cleanup. Engineered inspections at every milestone.</p>
        </div>
        <div class="process-card process-card-accent">
          <div class="text-xs font-bold uppercase tracking-widest text-accent-500 mb-2">Step 4</div>
          <h3 class="text-base mb-2">Final Inspection &amp; Handover</h3>
          <p class="text-sm text-brand-muted">City sign-off, engineer's stamp, warranty documentation, finishing handoff if bundled.</p>
        </div>
      </div>
    </div>
  </section>

  <section class="bg-accent-500 text-white py-12">
    <div class="max-w-container mx-auto px-4 flex flex-col lg:flex-row items-center justify-between gap-6">
      <div>
        <h2 class="text-white text-2xl lg:text-3xl mb-1">Not Sure What Your Basement Needs?</h2>
        <p class="text-white/90">Free engineered assessment. Honest answer, even when it isn't underpinning.</p>
      </div>
      <div class="flex flex-wrap gap-3">
        <a href="/contact/" class="btn bg-white text-primary-800 hover:bg-brand-bg">Book Estimate</a>
        <a href={site.contact.phoneHref} class="btn btn-outline-light !border-white">
          Call {site.contact.phone}
        </a>
      </div>
    </div>
  </section>

  <Testimonials items={site.testimonials} />

  <Stats />

  <section class="py-14 lg:py-18 bg-primary-800 text-white">
    <div class="max-w-container mx-auto px-4">
      <div class="max-w-4xl mx-auto flex flex-col lg:flex-row items-center gap-8 lg:gap-12">
        <div class="flex-1">
          <span class="text-xs font-bold uppercase tracking-widest text-accent-400 block mb-3">Free Tool</span>
          <h2 class="text-white mb-2">Estimate Your Project Cost in 30 Seconds</h2>
          <span class="accent-bar"></span>
          <p class="text-primary-100 mt-4 mb-6 leading-relaxed">
            Plug in your foundation perimeter, target ceiling height, and any add-ons (waterproofing, sump pump, finishing). Our estimator gives you a calibrated range based on 20+ years of Toronto underpinning pricing data.
          </p>
          <a href="/tools/" class="btn btn-primary">Use Free Estimator</a>
        </div>
        <div class="lg:w-72 bg-primary-700 border border-primary-600 p-6 relative flex-shrink-0">
          <span class="corner-bracket"></span>
          <dl class="space-y-3 text-sm">
            <div class="flex justify-between">
              <dt class="text-primary-200">1 ft depth gain</dt>
              <dd class="text-white font-bold">~$200/linear ft</dd>
            </div>
            <div class="flex justify-between">
              <dt class="text-primary-200">2 ft depth gain</dt>
              <dd class="text-white font-bold">~$300/linear ft</dd>
            </div>
            <div class="flex justify-between">
              <dt class="text-primary-200">3 ft depth gain</dt>
              <dd class="text-white font-bold">~$450/linear ft</dd>
            </div>
            <div class="flex justify-between border-t border-primary-600 pt-3">
              <dt class="text-primary-200">Typical full project</dt>
              <dd class="text-accent-400 font-bold">$20K-$50K+</dd>
            </div>
          </dl>
          <p class="text-xs text-primary-300 mt-4">Estimates only. Use the calculator for your specific inputs.</p>
        </div>
      </div>
    </div>
  </section>

  <section class="py-16 lg:py-20 bg-white">
    <div class="max-w-container mx-auto px-4">
      <div class="text-center mb-10">
        <span class="section-label">Service Coverage</span>
        <h2 class="mt-3">Basement Underpinning Across the Greater Toronto Area</h2>
        <span class="accent-bar accent-bar-center"></span>
        <p class="text-brand-muted max-w-2xl mx-auto">
          Toronto, North York, Etobicoke, Scarborough, York, East York, Mississauga, Brampton, Markham, Vaughan, Richmond Hill, Oakville, Burlington, Pickering and surrounding regions.
        </p>
      </div>
      <div class="flex flex-wrap justify-center gap-3 mb-8 max-w-4xl mx-auto">
        {primaryLocations.map((l) => (
          <a href={`/service-areas/${l.slug}/`} class="bg-brand-bg border border-brand-border hover:border-accent-500 hover:text-accent-500 px-4 py-2 text-sm font-bold uppercase tracking-widest text-brand-text transition-colors focus-ring">
            {l.name}
          </a>
        ))}
      </div>
      <div class="text-center">
        <a href="/service-areas/" class="btn btn-outline-dark">View All Service Areas</a>
      </div>
