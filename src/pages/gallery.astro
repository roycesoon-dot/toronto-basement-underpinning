    areaLabel: 'North York',
  },
  {
    image: '/images/generated/gallery-etobicoke-weeping-tile-waterproofing.webp',
    alt: 'Interior weeping tile installation with Delta-MS membrane on Etobicoke foundation wall',
    category: 'Waterproofing',
    title: 'Etobicoke Semi — Interior Weeping Tile + Delta-MS Membrane',
    description:
