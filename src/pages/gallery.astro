  {
    image: '/images/generated/gallery-mississauga-sump-battery-backup.webp',
    alt: 'Sealed sump pit lid with primary and battery backup pump installation in Mississauga basement',
    category: 'Waterproofing',
    title: 'Mississauga Detached — Sump Pump + Battery Backup System',
    description:
      'New sealed sump pit with Zoeller M53 primary, Basement Watchdog BWC1 battery backup, and high-water alarm. Installed during underpinning scope.',
    scope: 'Zoeller M53 + BWC1 battery backup',
    serviceHref: '/sump-pumps/',
    serviceLabel: 'Sump Pumps & Backups',
    areaHref: '/service-areas/mississauga/',
    areaLabel: 'Mississauga',
  },
  {
    image: '/images/generated/gallery-east-york-walkout-excavation.webp',
    alt: 'Walkout basement stairwell excavation with structural steel lintel installation in East York',
