    areaLabel: 'Midtown Toronto',
  },
  {
    image: '/images/generated/gallery-brampton-foundation-parging.webp',
    alt: 'Foundation parging coat and waterproof coating applied to block foundation in Brampton',
    category: 'Foundation Repair',
    title: 'Brampton Block Foundation — Parging + Waterproof Coating',
    description:
      'Deteriorating block foundation with spalling mortar joints. Full parging coat application, Drylok Extreme waterproof coating, grading corrected at grade.',
    scope: 'Parging coat, Drylok Extreme, grading correction',
