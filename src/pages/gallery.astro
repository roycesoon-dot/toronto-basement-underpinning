const categories = ['All', ...Array.from(new Set(projects.map((p) => p.category)))];
---

<BaseLayout
  title={title}
  description={description}
  pageType="default"
>

  <!-- Hero -->
  <section class="relative bg-primary-800 py-16 lg:py-24 overflow-hidden">
    <img
      src="/images/misc/toronto-basement-underpinning-specialists-staged-e.webp"
      alt=""
      aria-hidden="true"
      class="absolute inset-0 w-full h-full object-cover opacity-20"
      fetchpriority="high"
      loading="eager"
    />
    <div class="relative z-10 max-w-container mx-auto px-4">
      <span class="inline-block px-4 py-1.5 bg-accent-500 text-white text-xs font-bold uppercase tracking-wider mb-5">
        Project Gallery
      </span>
      <h1 class="text-white text-4xl lg:text-5xl font-extrabold leading-tight mb-4 max-w-3xl">
        Toronto Basement Underpinning Projects Across the GTA
      </h1>
      <p class="text-primary-100 text-lg max-w-2xl mb-6">
        Real job-site photos from our crews. Underpinning, waterproofing, walkout excavations, and basement finishing — completed across Toronto and the Greater Toronto Area.
      </p>
      <p class="text-primary-200 text-sm italic">
        Licensed & Insured. Engineered on every project. 20 active crews.
      </p>
    </div>
  </section>

  <TrustBar />

  <!-- Filter + Grid -->
  <section class="py-16 bg-brand-bg px-4">
    <div class="max-w-container mx-auto">

      <!-- Category Filter -->
      <div class="flex flex-wrap gap-3 mb-10" id="filter-bar">
        {categories.map((cat) => (
          <button
            class="filter-btn px-5 py-2 text-sm font-semibold border border-brand-border bg-white text-brand-text hover:border-accent-500 hover:text-accent-500 transition-colors"
            data-category={cat}
            aria-pressed={cat === 'All' ? 'true' : 'false'}
          >
            {cat}
          </button>
        ))}
      </div>

      <!-- Grid -->
      <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6" id="gallery-grid">
        {projects.map((p) => (
          <article
            class="gallery-card group bg-white overflow-hidden hover:shadow-lg transition-shadow border border-brand-border"
            data-category={p.category}
          >
            <!-- Image -->
            <div class="aspect-video overflow-hidden relative">
              <img
                src={p.image}
                alt={p.alt}
                loading="lazy"
                decoding="async"
                class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
              />
              <span class="absolute top-3 left-3 bg-primary-800/90 text-accent-400 text-[11px] font-bold uppercase tracking-wider px-3 py-1">
                {p.category}
              </span>
            </div>

            <!-- Content -->
            <div class="p-6">
              <h2 class="text-lg font-bold text-primary-800 mb-2 leading-snug">{p.title}</h2>
              <p class="text-sm text-brand-text mb-3 leading-relaxed">{p.description}</p>
              <p class="text-xs text-brand-muted mb-4">
                <strong>Scope:</strong> {p.scope}
              </p>
              <div class="flex flex-wrap gap-2 text-xs">
                <a
                  href={p.serviceHref}
                  class="inline-block px-3 py-1 bg-accent-500 text-white font-semibold hover:bg-accent-600 transition-colors"
                >
                  {p.serviceLabel}
                </a>
                <a
                  href={p.areaHref}
                  class="inline-block px-3 py-1 bg-white border border-brand-border text-brand-text font-semibold hover:bg-brand-bg transition-colors"
                >
                  {p.areaLabel}
                </a>
              </div>
            </div>
          </article>
        ))}
      </div>

      <!-- Empty state (hidden by default) -->
      <p class="hidden text-center text-brand-muted py-12" id="no-results">
        No projects in that category yet.
      </p>
    </div>
  </section>

  <CTA />

</BaseLayout>

<script>
  const filterBar = document.getElementById('filter-bar');
  const cards = document.querySelectorAll<HTMLElement>('.gallery-card');
  const noResults = document.getElementById('no-results');

  filterBar?.addEventListener('click', (e) => {
    const btn = (e.target as HTMLElement).closest<HTMLButtonElement>('.filter-btn');
    if (!btn) return;

    const category = btn.dataset.category ?? 'All';

    // Update active state
    filterBar.querySelectorAll<HTMLButtonElement>('.filter-btn').forEach((b) => {
      const active = b.dataset.category === category;
      b.setAttribute('aria-pressed', active ? 'true' : 'false');
      b.classList.toggle('!bg-primary-800', active);
      b.classList.toggle('!text-white', active);
      b.classList.toggle('!border-primary-800', active);
    });

    // Show/hide cards
    let visible = 0;
    cards.forEach((card) => {
      const show = category === 'All' || card.dataset.category === category;
      card.style.display = show ? '' : 'none';
      if (show) visible++;
    });

    noResults?.classList.toggle('hidden', visible > 0);
  });

  // Set All active on load
  filterBar?.querySelector<HTMLButtonElement>('[data-category="All"]')?.click();
</script>
