---
import BaseLayout from '../layouts/BaseLayout.astro';
import site from '../config/site.json';

const lastUpdated = new Date().toLocaleDateString('en-CA', { year: 'numeric', month: 'long', day: 'numeric' });
---

<BaseLayout
  title={`Privacy Policy | ${site.name}`}
  description={`Privacy policy for ${site.name}. How we collect, use, and protect your personal information.`}
  pageType="default"
>
  <section class="bg-primary-800 text-white py-12">
    <div class="max-w-container mx-auto px-4">
      <h1 class="text-white mb-2">Privacy Policy</h1>
      <span class="accent-bar"></span>
      <p class="text-sm text-primary-200">Last updated: {lastUpdated}</p>
    </div>
  </section>

  <section class="py-16 bg-white">
    <div class="max-w-3xl mx-auto px-4 prose-tbu">
      <p>
        {site.name} (&ldquo;we&rdquo;, &ldquo;us&rdquo;, or &ldquo;our&rdquo;) respects your privacy. This policy explains what information we collect, how we use it, and your rights.
      </p>

      <h2>1. Information We Collect</h2>
      <p>We collect information you provide directly when you contact us, request an estimate, or hire us for a project, including:</p>
      <ul>
        <li>Name and contact information (email, phone, address)</li>
        <li>Project details (basement dimensions, current ceiling height, scope of work)</li>
        <li>Communication history with our team</li>
        <li>Payment information (processed by third-party payment providers)</li>
      </ul>

      <h2>2. How We Use Your Information</h2>
      <p>We use the information we collect to:</p>
      <ul>
        <li>Provide and improve our basement underpinning, waterproofing, finishing, and related services</li>
        <li>Schedule on-site estimates and project visits</li>
        <li>Coordinate architectural drawings, structural engineering, and City of Toronto permit submissions</li>
        <li>Respond to your questions and project inquiries</li>
        <li>Process project payments and warranty claims</li>
      </ul>

      <h2>3. Information Sharing</h2>
      <p>We do not sell your personal information. We share information only with:</p>
      <ul>
        <li>Our architectural and structural-engineering partners working on your project</li>
        <li>Municipal building departments when filing permits on your behalf</li>
        <li>Subcontractors directly involved in your project work</li>
        <li>Authorities when required by law</li>
      </ul>

      <h2>4. Data Security</h2>
      <p>We use commercially reasonable safeguards to protect your information from unauthorized access. No system is perfectly secure; we do not represent that the safeguards are absolute.</p>

      <h2>5. Your Rights</h2>
      <p>You have the right to:</p>
      <ul>
        <li>Access the personal information we hold about you</li>
        <li>Request corrections to inaccurate information</li>
        <li>Request deletion of your information (subject to record-keeping obligations)</li>
        <li>Opt out of marketing communications</li>
      </ul>

      <h2>6. Cookies &amp; Analytics</h2>
      <p>This website may use cookies and analytics tools to understand site usage. You can disable cookies in your browser settings; some site features may not function without them.</p>

      <h2>7. Contact</h2>
      <p>Questions about this Privacy Policy? Contact us:</p>
      <ul>
        <li>Email: <a href={`mailto:${site.contact.email}`}>{site.contact.email}</a></li>
        <li>Phone: <a href={site.contact.phoneHref}>{site.contact.phone}</a></li>
        <li>Address: {site.address.full}</li>
      </ul>
    </div>
  </section>
</BaseLayout>
