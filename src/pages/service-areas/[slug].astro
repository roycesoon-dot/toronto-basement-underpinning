---
import BaseLayout from '../../layouts/BaseLayout.astro';
import TrustBar from '../../components/blocks/TrustBar.astro';
import Testimonials from '../../components/blocks/Testimonials.astro';
import FAQ from '../../components/blocks/FAQ.astro';
import CTA from '../../components/blocks/CTA.astro';
import locations from '../../config/locations.json';
import site from '../../config/site.json';
import faqData from '../../config/faq.json';
import { getCollection } from 'astro:content';

export async function getStaticPaths() {
  return locations.map((location) => ({
    params: { slug: location.slug },
    props: { location },
  }));
}

const { location } = Astro.props;
const locationsPath = site.urlPatterns.locationsPath;

const services = (await getCollection('services')).filter((s) => s.data.featured);

const meta = location.metaTitle || `Basement Underpinning ${location.name} | ${site.name}`;
const description = location.metaDescription || location.description;
const h1 = location.h1Title || `Basement Underpinning in ${location.name}`;

const heroImage = "/images/misc/indoor-finished-basement-service-areas-hero.webp";

const nearbyLocations = (location.nearby || [])
  .map((slug) => locations.find((l) => l.slug === slug))
  .filter((l): l is typeof locations[number] => Boolean(l));

const fallbackTestimonials = site.testimonials.slice(0, 3).map((t) => ({
  quote: t.quote,
  name: t.name,
  rating: t.rating,
  location: t.location,
}));

// Prefer location-specific FAQs, fall back to global featured FAQs
const featuredFaqs = faqData.filter((f: any) => f.featured);
const locationFaqs = (location.localFAQs && location.localFAQs.length > 0)
  ? location.localFAQs
  : featuredFaqs;

// Section headings with fallbacks
const sh = location.sectionHeadings || {};
const heading = {
  painPoints: sh.painPoints || `Basement Underpinning Problems in ${location.name}?`,
  services:   sh.services   || `Professional Basement Underpinning in ${location.name}`,
  process:    sh.process    || `How Our ${location.name} Underpinning Works`,
  midCta:     sh.midCta     || `Need Basement Underpinning in ${location.name}?`,
  whyChooseUs:sh.whyChooseUs|| `Why ${location.name} Residents Choose Us`,
  localContent:sh.localContent || `Our Underpinning Expertise in ${location.name}`,
  faq:        sh.faq        || `${location.name} Underpinning Questions Answered`,
  finalCta:   sh.finalCta   || `Need Basement Underpinning in ${location.name}? Contact Us Now`,
};

const locationSchema = {
  '@context': 'https://schema.org',
  '@type': site.schema.type,
  '@id': `${site.url}/service-areas/${location.slug}/#location`,
  name: `${site.name} - ${location.name}`,
  description: location.description,
  parentOrganization: { '@id': `${site.url}/#organization` },
  url: `${site.url}/service-areas/${location.slug}/`,
  telephone: site.contact.phone,
  areaServed: {
    '@type': 'City',
    name: location.name,
    containedInPlace: { '@type': 'State', name: 'Ontario' },
  },
  ...(location.coordinates ? {
    geo: {
      '@type': 'GeoCoordinates',
      latitude: location.coordinates.lat,
      longitude: location.coordinates.lng,
    }
  } : {}),
  address: {
    '@type': 'PostalAddress',
    addressLocality: location.name,
    addressRegion: 'ON',
    addressCountry: 'CA',
  },
  hasMap: `https://www.google.com/maps/search/?api=1&query=${encodeURIComponent(`${location.name}, Ontario, Canada`)}`,
  hasOfferCatalog: {
    '@type': 'OfferCatalog',
    name: `Services in ${location.name}`,
    itemListElement: services.map((s) => ({
      '@type': 'Offer',
      itemOffered: {
        '@type': 'Service',
        '@id': `${site.url}/${s.slug}/#service`,
        name: s.data.title,
      },
    })),
  },
};

const breadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: site.url + '/' },
    { '@type': 'ListItem', position: 2, name: 'Service Areas', item: `${site.url}/service-areas/` },
    { '@type': 'ListItem', position: 3, name: location.name, item: `${site.url}/service-areas/${location.slug}/` },
  ],
};

---

<BaseLayout title={meta} description={description} pageType="location_pages">
  <script type="application/ld+json" set:html={JSON.stringify(locationSchema)} slot="head" />
  <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} slot="head" />

  <!-- Hero -->
  <section class="relative overflow-hidden bg-primary-800 text-white">
    <div class="absolute inset-0 z-0">
      <img src={heroImage} alt="" class="w-full h-full object-cover" loading="eager" />
      <div class="absolute inset-0 bg-gradient-to-r from-primary-800/95 via-primary-800/85 to-primary-700/55"></div>
    </div>
    <div class="relative z-10 max-w-container mx-auto px-4 py-14 lg:py-24">
      <nav class="text-xs text-primary-200 mb-4 flex flex-wrap gap-1.5 items-center" aria-label="Breadcrumb">
        <a href="/" class="hover:text-accent-400">Home</a>
        <span class="text-primary-400">&rsaquo;</span>
        <a href="/service-areas/" class="hover:text-accent-400">Service Areas</a>
        <span class="text-primary-400">&rsaquo;</span>
        <span class="text-white">{location.name}</span>
      </nav>

      <span class="inline-block bg-accent-500/20 border border-accent-500 text-accent-300 text-xs font-bold uppercase tracking-widest px-3 py-1.5 mb-4">
        {location.responseTime} &middot; {location.council}
      </span>
      <h1 class="text-white mb-4 max-w-4xl">{h1}</h1>
      <span class="accent-bar"></span>
      <p class="text-lg text-primary-100 max-w-2xl mb-8">{location.description}</p>

      <div class="flex flex-wrap gap-3 mb-6">
        <a href="/contact/" class="btn btn-primary">Get a Free {location.shortName} Estimate</a>
        <a href={site.contact.phoneHref} class="btn btn-outline-light">
          Call {site.contact.phone}
        </a>
      </div>

      {location.areas && location.areas.length > 0 && (
        <div class="mt-8">
          <p class="text-xs font-bold uppercase tracking-widest text-accent-400 mb-2">Neighbourhoods Served</p>
          <div class="flex flex-wrap gap-2">
            {location.areas.map((a) => (
              <span class="text-xs bg-white/10 border border-white/20 px-3 py-1.5 text-primary-100">{a}</span>
            ))}
          </div>
        </div>
      )}
    </div>
  </section>

  <TrustBar />

  <!-- Pain Points -->
  <section class="py-16 lg:py-20 bg-white">
    <div class="max-w-container mx-auto px-4">
      <div class="text-center mb-12">
        <span class="section-label">Common Problems</span>
        <h2 class="mt-3">{heading.painPoints}</h2>
        <span class="accent-bar accent-bar-center"></span>
        <p class="text-brand-muted max-w-2xl mx-auto">
          The homeowners we work with are usually wrestling with one of these. We solve them properly  -  not with a quick fix that fails in two years.
        </p>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-5">
        <div class="tbu-card p-6 relative">
          <span class="corner-bracket"></span>
          <h3 class="text-lg mb-2">Cramped Ceiling Height</h3>
          <p class="text-brand-muted text-sm leading-relaxed">
            Your {location.shortName} basement ceiling is under 7 feet  -  finishing the space feels claustrophobic and a legal apartment is impossible at that height.
          </p>
        </div>
        <div class="tbu-card p-6 relative">
          <span class="corner-bracket"></span>
          <h3 class="text-lg mb-2">Cracked Foundation Walls</h3>
          <p class="text-brand-muted text-sm leading-relaxed">
            Recurring or stair-step cracks in your {location.shortName} foundation signal active settlement. Patches keep failing because the underlying bearing problem continues.
          </p>
        </div>
        <div class="tbu-card p-6 relative">
          <span class="corner-bracket"></span>
          <h3 class="text-lg mb-2">Leaking Basement</h3>
          <p class="text-brand-muted text-sm leading-relaxed">
            Water at the wall-floor cove every spring in your {location.shortName} home. The original weeping tile is clogged, cracked, or aged out.
          </p>
        </div>
        <div class="tbu-card p-6 relative">
          <span class="corner-bracket"></span>
          <h3 class="text-lg mb-2">Stalled By Permits</h3>
          <p class="text-brand-muted text-sm leading-relaxed">
            Building permits, structural engineering, and the plan-review process in {location.shortName} feel like a maze. We handle all of it.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- Services Grid -->
  <section class="py-16 lg:py-20 bg-brand-bg">
    <div class="max-w-container mx-auto px-4">
      <div class="text-center mb-12">
        <span class="section-label">Our Services</span>
        <h2 class="mt-3">{heading.services}</h2>
        <span class="accent-bar accent-bar-center"></span>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
        {services.map((s) => (
          <a href={`/${s.slug}/`} class="block group bg-white border border-brand-border hover:border-accent-500 transition-colors relative focus-ring">
            <span class="corner-bracket"></span>
            <div class="aspect-[4/3] overflow-hidden bg-primary-800">
              <img src={s.data.image} alt={s.data.title} class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500" loading="lazy" />
            </div>
            <div class="p-5">
              <h3 class="text-base mb-2 leading-tight">{s.data.title}</h3>
              <p class="text-sm text-brand-muted leading-relaxed">{s.data.description} Available in {location.shortName} as part of our full-turnkey underpinning service.</p>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- Process Steps -->
  <section class="py-16 lg:py-20 bg-white">
    <div class="max-w-container mx-auto px-4">
      <div class="text-center mb-12">
        <span class="section-label">How It Works</span>
        <h2 class="mt-3">{heading.process}</h2>
        <span class="accent-bar accent-bar-center"></span>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-4 gap-5">
        <div class="process-card">
          <div class="text-xs font-bold uppercase tracking-widest text-accent-500 mb-2">Step 1</div>
          <h3 class="text-base mb-2">Free Site Visit</h3>
          <p class="text-sm text-brand-muted">Engineered assessment at your {location.shortName} property. Fixed-price quote within two business hours.</p>
        </div>
        <div class="process-card process-card-accent">
          <div class="text-xs font-bold uppercase tracking-widest text-accent-500 mb-2">Step 2</div>
          <h3 class="text-base mb-2">Drawings &amp; Permits</h3>
          <p class="text-sm text-brand-muted">Architect, structural engineer, {location.shortName} building permit submission. We handle every form and every hearing.</p>
        </div>
        <div class="process-card">
          <div class="text-xs font-bold uppercase tracking-widest text-accent-500 mb-2">Step 3</div>
          <h3 class="text-base mb-2">Staged Construction</h3>
          <p class="text-sm text-brand-muted">Pin-section excavation and pours in {location.shortName}. Daily site cleanup. Engineered inspections at every milestone.</p>
        </div>
        <div class="process-card process-card-accent">
          <div class="text-xs font-bold uppercase tracking-widest text-accent-500 mb-2">Step 4</div>
          <h3 class="text-base mb-2">Inspection &amp; Handover</h3>
          <p class="text-sm text-brand-muted">City sign-off, engineer's stamp, warranty documentation, finishing handoff if bundled in {location.shortName}.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Mid-Page CTA (Risk Reversal) -->
  <section class="bg-accent-500 text-white py-12">
    <div class="max-w-container mx-auto px-4 flex flex-col lg:flex-row items-center justify-between gap-6">
      <div>
        <h2 class="text-white text-2xl lg:text-3xl mb-1">{heading.midCta}</h2>
        <p class="text-white/90">Free engineered assessment. Zero-risk, no-questions-asked warranty on every project.</p>
      </div>
      <div class="flex flex-wrap gap-3">
        <a href="/contact/" class="btn bg-white text-primary-800 hover:bg-brand-bg">Book Free Estimate</a>
        <a href={site.contact.phoneHref} class="btn btn-outline-light !border-white">
          Call {site.contact.phone}
        </a>
      </div>
    </div>
  </section>

  <!-- Why Choose Us -->
  {location.modules?.whyChooseUs && (
    <section class="py-16 lg:py-20 bg-brand-bg">
      <div class="max-w-container mx-auto px-4">
        <div class="text-center mb-12">
          <span class="section-label">Local Expertise</span>
          <h2 class="mt-3">{heading.whyChooseUs}</h2>
          <span class="accent-bar accent-bar-center"></span>
        </div>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-4 max-w-5xl mx-auto">
          {location.modules.whyChooseUs.points.map((p) => (
            <div class="flex items-start gap-3 bg-white border border-brand-border p-5">
              <svg class="w-5 h-5 text-accent-500 flex-shrink-0 mt-0.5" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd" /></svg>
              <span class="text-sm text-brand-text">{p}</span>
            </div>
          ))}
        </div>
      </div>
    </section>
  )}

  <!-- Local Expertise Modules -->
  {(location.modules?.localLogistics || location.modules?.buildingFamiliarity) && (
    <section class="py-16 lg:py-20 bg-white">
      <div class="max-w-container mx-auto px-4">
        <div class="text-center mb-10">
          <span class="section-label">Local Knowledge</span>
          <h2 class="mt-3">{heading.localContent}</h2>
          <span class="accent-bar accent-bar-center"></span>
        </div>
        <div class="grid lg:grid-cols-2 gap-10 max-w-5xl mx-auto">
          {location.modules?.localLogistics && (
            <div>
              <h3 class="text-xl mb-2">{location.modules.localLogistics.headline}</h3>
              <span class="accent-bar"></span>
              <p class="text-brand-text leading-relaxed">{location.modules.localLogistics.content}</p>
            </div>
          )}
          {location.modules?.buildingFamiliarity && (
            <div>
              <h3 class="text-xl mb-2">{location.modules.buildingFamiliarity.headline}</h3>
              <span class="accent-bar"></span>
              <p class="text-brand-text leading-relaxed">{location.modules.buildingFamiliarity.content}</p>
            </div>
          )}
        </div>
      </div>
    </section>
  )}

  <!-- Landmarks -->
  {location.landmarks && location.landmarks.length > 0 && (
    <section class="py-12 bg-brand-bg">
      <div class="max-w-container mx-auto px-4">
        <div class="max-w-4xl mx-auto">
          <h2 class="text-center text-2xl mb-2">{location.name} Landmarks We Work Near</h2>
          <span class="accent-bar accent-bar-center"></span>
          <div class="flex flex-wrap justify-center gap-2 mt-6">
            {location.landmarks.map((l) => (
              <span class="text-xs bg-white border border-brand-border px-4 py-2 text-brand-text">{l}</span>
            ))}
          </div>
        </div>
      </div>
    </section>
  )}

  <!-- Google Maps Embed -->
  {location.mapEmbed && (
    <section class="py-12 bg-white">
      <div class="max-w-container mx-auto px-4">
        <div class="max-w-4xl mx-auto">
          <h2 class="text-center text-xl mb-6">Our Service Area in {location.name}</h2>
          <div class="rounded-none overflow-hidden border border-brand-border shadow-sm">
            <iframe
              src={location.mapEmbed}
              class="w-full h-80 lg:h-96"
              style="border:0;"
              allowfullscreen=""
              loading="lazy"
              referrerpolicy="no-referrer-when-downgrade"
              title={`Map of ${location.name}`}
            />
          </div>
        </div>
      </div>
    </section>
  )}

  <!-- Testimonials -->
  <Testimonials
    items={fallbackTestimonials}
    title={`What Homeowners Say`}
  />

  <!-- FAQ -->
  {locationFaqs && locationFaqs.length > 0 && (
    <FAQ items={locationFaqs} title={heading.faq} />
  )}

  <!-- Nearby Areas -->
  {nearbyLocations.length > 0 && (
    <section class="py-16 bg-brand-bg">
      <div class="max-w-container mx-auto px-4">
        <div class="text-center mb-10">
          <span class="section-label">Nearby Areas</span>
          <h2 class="mt-3">Also Serving</h2>
          <span class="accent-bar accent-bar-center"></span>
        </div>
        <div class="grid grid-cols-1 md:grid-cols-3 gap-4 max-w-4xl mx-auto">
          {nearbyLocations.map((n) => (
            <a href={`/${locationsPath}/${n.slug}/`} class="block tbu-card p-5 hover:border-accent-500 transition-colors group focus-ring">
              <h3 class="text-base mb-1 leading-tight group-hover:text-accent-500 transition-colors">{n.name}</h3>
              <p class="text-xs text-brand-muted">{n.council}</p>
            </a>
          ))}
        </div>
      </div>
    </section>
  )}

  <CTA
    headline={heading.finalCta}
    subheadline={`Free estimate within two business hours. Local crews, ${location.responseTime.toLowerCase()}.`}
  />
</BaseLayout>
