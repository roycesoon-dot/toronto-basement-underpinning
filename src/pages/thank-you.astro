---
import BaseLayout from '../layouts/BaseLayout.astro';
import site from '../config/site.json';
---

<BaseLayout
  title={`Thank You | ${site.name}`}
  description="Thank you for your estimate request. Our team will respond within two business hours."
  noindex={true}
>
  <section class="bg-primary-800 text-white py-14 lg:py-16">
    <div class="max-w-container mx-auto px-4">
      <span class="section-label !text-accent-400">Estimate Request Received</span>
      <h1 class="text-white mt-3 mb-4 max-w-3xl">We Got Your Message</h1>
      <span class="accent-bar"></span>
      <p class="text-lg text-primary-100 max-w-2xl">
        Thank you for reaching out. Our team will review your project details and get back to you within two business hours with a free, fixed-price estimate.
      </p>
    </div>
  </section>

  <section class="py-16 lg:py-20 bg-white">
    <div class="max-w-container mx-auto px-4">
      <div class="max-w-2xl mx-auto text-center">

        <!-- Success icon -->
        <div class="w-20 h-20 rounded-full flex items-center justify-center mx-auto mb-8" style="background-color: var(--color-accent-100, #fef9ec);">
          <svg xmlns="http://www.w3.org/2000/svg" class="w-10 h-10" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5" style="color: var(--color-accent-600, #b45309);">
            <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
          </svg>
        </div>

        <h2 class="mb-4">Estimate Request Submitted</h2>
        <p class="text-brand-muted text-lg mb-8 leading-relaxed">
          One of our estimators will contact you within two business hours during business hours (Mon–Fri 8am–6pm, Sat 9am–3pm). For faster service, call us directly.
        </p>

        <a href={site.contact.phoneHref} class="btn btn-primary inline-flex items-center gap-2 mb-4">
          <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 8V5z" />
          </svg>
          Call {site.contact.phone} Now
        </a>

        <div class="mt-4">
          <a href="/" class="text-sm text-brand-muted hover:text-accent-600 underline underline-offset-2">← Back to homepage</a>
        </div>

        <div class="mt-12 bg-brand-bg border border-brand-border p-6 text-left relative">
          <span class="corner-bracket"></span>
          <h3 class="text-base mb-4">What Happens Next</h3>
          <ol class="space-y-3 text-sm text-brand-muted">
            <li class="flex gap-3">
              <span class="font-bold text-accent-600 shrink-0">01</span>
              <span>Our estimator reviews your project details and property address.</span>
            </li>
            <li class="flex gap-3">
              <span class="font-bold text-accent-600 shrink-0">02</span>
              <span>We contact you by phone or email within two business hours with questions and a preliminary quote range.</span>
            </li>
            <li class="flex gap-3">
              <span class="font-bold text-accent-600 shrink-0">03</span>
              <span>We schedule a free on-site assessment at a time that works for you — no obligation.</span>
            </li>
            <li class="flex gap-3">
              <span class="font-bold text-accent-600 shrink-0">04</span>
              <span>You receive a written, fixed-price quote. No surprises, no change orders.</span>
            </li>
          </ol>
        </div>

      </div>
    </div>
  </section>
</BaseLayout>
